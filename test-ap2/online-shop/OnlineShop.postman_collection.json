  "item": [
    {
      "name": "1. Users & Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.user && json.user.id) pm.collectionVariables.set('user_id', json.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"name\": \"{{name}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/users/register"
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('token', json.access_token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "if (json.user && json.user.id) pm.collectionVariables.set('user_id', json.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/users/login"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('token', json.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/auth/logout"
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/users/verify?token={{verify_token}}"
          }
        },
        {
          "name": "Resend Verification",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/users/resend-verification"
          }
        },
        {
          "name": "Get Me",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/users/me"
          }
        },
        {
          "name": "List Users",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/users?page=1&limit=10"
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/users/{{user_id}}"
          }
        },
        {
          "name": "Update User",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{name}} Updated\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/users/{{user_id}}"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"old_password\": \"{{password}}\",\n  \"new_password\": \"{{new_password}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/users/{{user_id}}/password"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/users/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "2. Products",
      "item": [
        {
          "name": "List Products",
          "request": { "method": "GET", "header": [], "url": "{{base_url}}/products?page=1&limit=10" }
        },
        {
          "name": "Search Products",
          "request": { "method": "GET", "header": [], "url": "{{base_url}}/products/search?q={{search_query}}&page=1&limit=10" }
        },
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.product && json.product.id) pm.collectionVariables.set('product_id', json.product.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{product_name}}\",\n  \"description\": \"{{product_description}}\",\n  \"price\": 1200000,\n  \"stock\": 5,\n  \"category_id\": \"{{category_id}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/products"
          }
        },
        {
          "name": "Get Product By ID",
          "request": { "method": "GET", "header": [], "url": "{{base_url}}/products/{{product_id}}" }
        },
        {
          "name": "Get Product Reviews",
          "request": { "method": "GET", "header": [], "url": "{{base_url}}/products/{{product_id}}/reviews" }
        },
        {
          "name": "Update Product",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{product_name}} Updated\",\n  \"description\": \"{{product_description}} Updated\",\n  \"price\": 1250000,\n  \"category_id\": \"{{category_id}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/products/{{product_id}}"
          }
        },
        {
          "name": "Update Product Stock",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 10\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/products/{{product_id}}/stock"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/products/{{product_id}}"
          }
        }
      ]
    },
    {
      "name": "3. Categories",
      "item": [
        {
          "name": "List Categories",
          "request": { "method": "GET", "header": [], "url": "{{base_url}}/categories" }
        },
