            "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{category_name}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/categories"
          }
        },
        {
          "name": "Create Category Via Products Alias",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
