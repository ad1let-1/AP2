    {
      "name": "4. Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.order && json.order.id) pm.collectionVariables.set('order_id', json.order.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"items\": [\n    {\n      \"product_id\": \"{{product_id}}\",\n      \"quantity\": 1,\n      \"price\": 1200000\n    }\n  ]\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "List Orders",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/orders?page=1&limit=10"
          }
        },
        {
          "name": "Calculate Total",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"items\": [\n    {\n      \"product_id\": \"{{product_id}}\",\n      \"quantity\": 2,\n      \"price\": 1200000\n    }\n  ],\n  \"discount_code\": \"{{discount_code}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/orders/calculate"
          }
        },
        {
          "name": "Get Order By ID",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/orders/{{order_id}}"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/orders/{{order_id}}/cancel"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"paid\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/orders/{{order_id}}/status"
          }
        },
        {
          "name": "Track Order",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/orders/{{order_id}}/track"
          }
        },
        {
          "name": "Apply Discount",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"discount_code\": \"{{discount_code}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/orders/{{order_id}}/discount"
          }
        },
        {
          "name": "Add Item To Order",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"item\": {\n    \"product_id\": \"{{product_id}}\",\n    \"quantity\": 1,\n    \"price\": 1200000\n  }\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/orders/{{order_id}}/items"
          }
        },
        {
          "name": "Remove Item From Order",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/orders/{{order_id}}/items/{{product_id}}"
          }
        }
