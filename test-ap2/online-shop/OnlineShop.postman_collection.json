{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-4a5b-8c9d-0e1f2a3b4c5d",
    "name": "Online Shop API - Full",
    "description": "Full REST collection for the API Gateway. Run Register/Login first, then create a category, product, order, and payment to fill chained variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
